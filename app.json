{
  "expo": {
    "name": "Centro SIS",
    "slug": "centro-sis",
    "version": "1.5.0",
    "orientation": "portrait",
    "icon": "./assets/images/logo-centro.png",
    "scheme": "centrosis",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "android": {
      "package": "com.estonianport.centrosis",
      "versionCode": 5,
      "adaptiveIcon": {
        "backgroundColor": "#2D3C59",
        "foregroundImage": "./assets/images/logo.png"
      },
      "navigationBar": {
        "backgroundColor": "#ffffff",
        "barStyle": "dark-content"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "ios": {
      "bundleIdentifier": "com.estonianport.centrosis",
      "buildNumber": "5",
      "supportsTablet": true
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/logo-centro.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/logo-centro.png",
          "resizeMode": "cover",
          "backgroundColor": "#ffffff"
        }
      ],
      "expo-web-browser",
      "@react-native-community/datetimepicker",
      "expo-asset"
    ],
    "assetBundlePatterns": [
      "**/*"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
